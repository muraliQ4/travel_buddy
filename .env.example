# Environment Variables Configuration
# Copy this file to .env and fill in your values

# ======================
# SERVER CONFIGURATION
# ======================
PORT=5000
NODE_ENV=development

# ======================
# DATABASE
# ======================
MONGODB_URI=mongodb://localhost:27017/travelbuddy
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/travelbuddy?retryWrites=true&w=majority

# ======================
# AUTHENTICATION
# ======================
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

# ======================
# WEATHER API (OpenWeatherMap)
# ======================
# Get your API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ======================
# PAYMENT GATEWAYS (Optional)
# ======================
# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe (if using Stripe instead)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ======================
# NOTIFICATION SERVICES (Optional)
# ======================
# Twilio for SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid for Email
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@travelbuddy.com

# Firebase Cloud Messaging for Push Notifications
FCM_SERVER_KEY=your_fcm_server_key

# ======================
# MAP SERVICES (Optional)
# ======================
# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Mapbox (alternative)
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# ======================
# STORAGE (Optional - for file uploads)
# ======================
# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=travelbuddy-uploads

# Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ======================
# INSURANCE PROVIDER (Optional)
# ======================
INSURANCE_API_KEY=your_insurance_provider_api_key
INSURANCE_API_URL=https://insurance-api.example.com

# ======================
# AI SERVICES (Optional)
# ======================
# OpenAI for advanced features
OPENAI_API_KEY=your_openai_api_key

# ======================
# CORS CONFIGURATION
# ======================
# Frontend URLs (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://yourdomain.com

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ======================
# SESSION CONFIGURATION
# ======================
SESSION_SECRET=your_session_secret_here
SESSION_COOKIE_MAX_AGE=604800000

# ======================
# ADMIN CREDENTIALS
# ======================
ADMIN_EMAIL=admin@travelbuddy.com
ADMIN_PASSWORD=change_this_in_production

# ======================
# FEATURE FLAGS (Enable/Disable Features)
# ======================
FEATURE_INSURANCE_ENABLED=true
FEATURE_KIDS_MODE_ENABLED=true
FEATURE_WEATHER_ALERTS_ENABLED=true
FEATURE_AI_PRICING_ENABLED=true

# ======================
# FRONTEND (VITE)
# ======================
# Backend origin for frontend API calls (without /api)
VITE_API_BASE_URL=http://localhost:5000

# Optional: socket endpoint override (if different from API base)
# VITE_SOCKET_URL=http://localhost:5000
FEATURE_QR_CHECKIN_ENABLED=true
FEATURE_NIGHT_SAFETY_ENABLED=true

# ======================
# PRICING CONFIGURATION
# ======================
# Base rates for AI pricing (per km in INR)
BASE_RATE_CAR=8
BASE_RATE_BIKE=5
BASE_RATE_SUV=10
BASE_RATE_VAN=12
BASE_RATE_BUS=6

# Fuel prices (per liter in INR)
FUEL_PRICE_PETROL=100
FUEL_PRICE_DIESEL=90

# ======================
# BUSINESS RULES
# ======================
# Cancellation policy
FREE_CANCELLATION_HOURS=24
LATE_CANCELLATION_PENALTY_PERCENT=50
NO_SHOW_PENALTY_PERCENT=100

# Referral rewards
REFERRAL_REWARD_POINTS=100
REFERRAL_REWARD_AMOUNT=50

# Minimum ratings
MINIMUM_DRIVER_RATING=3.5
MINIMUM_PASSENGER_RATING=3.0

# ======================
# SECURITY
# ======================
# Encryption key for sensitive data
ENCRYPTION_KEY=your_encryption_key_here

# Password hashing rounds
BCRYPT_ROUNDS=10

# ======================
# LOGGING
# ======================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/server.log

# ======================
# REDIS (for caching - optional)
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ======================
# WEBSOCKET (Socket.IO)
# ======================
SOCKET_IO_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ======================
# BACKUP CONFIGURATION
# ======================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ======================
# DEVELOPMENT/DEBUGGING
# ======================
DEBUG=true
VERBOSE_LOGGING=true

# ======================
# PRODUCTION SETTINGS (Change for production)
# ======================
# Set NODE_ENV=production
# Use strong JWT_SECRET
# Use secure MONGODB_URI
# Enable rate limiting
# Set DEBUG=false
# Use HTTPS only
# Configure proper CORS origins
